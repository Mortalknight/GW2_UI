<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/../../Blizzard_SharedXML/UI.xsd">
    <Button name="GwImmersiveQuestingButtonTemplate" inherits="GwStandardButton" virtual="true">
        <Size x="128" y="24" />
        <KeyValues>
            <KeyValue key="fitTextCanWidthDecrease" value="false" type="boolean"/>
            <KeyValue key="fitTextWidthPadding" value="40" type="number"/>
        </KeyValues>
    </Button>

    <Font name="GwImmersiveQuestingTitleFont" inherits="Game24Font" virtual="true">
        <Color r="1.0" g="0.77" b="0.15"/>
        <Shadow x="2" y="-2"><Color r="0" g="0" b="0"/></Shadow>
    </Font>

    <Font name="GwImmersiveQuestingDialogFont" inherits="Game15Font" virtual="true">
        <Color r="1.0" g="1.0" b="1.0"/>
    </Font>

    <Font name="GwImmersiveQuestingHeaderFont" inherits="QuestFont_Huge" virtual="true">
        <Color r="1.0" g="1.0" b="1.0"/>
        <Shadow x="1" y="-1"><Color r="0" g="0" b="0"/></Shadow>
    </Font>

    <Font name="GwImmersiveQuestingObjectiveFont" inherits="SystemFont_Med2" virtual="true">
        <Color r="1.0" g="1.0" b="1.0"/>
        <Shadow x="1" y="-1"><Color r="0" g="0" b="0"/></Shadow>
    </Font>
</Ui>
