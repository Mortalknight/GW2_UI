<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/../../Blizzard_SharedXML/UI.xsd">
    <Frame name="GwImmersiveQuestFrameTemplate" hidden="true" frameStrata="HIGH" mixin="GwImmersiveQuestFrameMixin" enableMouse="true" virtual="true">
        <Size x="1024" y="512"></Size>
        <Anchors>
            <Anchor point="center" x="0" y="0" />
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="border" file="Interface/AddOns/GW2_UI/textures/questview/border.png">
                    <Size x="1024" y="512"></Size>
                    <Anchors>
                        <Anchor point="center" x="0" y="0" />
                    </Anchors>
                </Texture>
                <Texture>
                    <Color r="0" g="0" b="0"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" x="48" y="-32"/>
                        <Anchor point="BOTTOMRIGHT" x="-48" y="32"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="BACKGROUND" textureSubLevel="3">
                <Texture file="Interface/AddOns/GW2_UI/textures/questview/overlay_top.png">
                    <Size x="950" y="237"></Size>
                    <Anchors>
                        <Anchor point="center" x="0" y="119"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Frame parentKey="container">
                <Size x="950" y="474"></Size>
                <Anchors>
                    <Anchor point="center" x="0" y="0"/>
                </Anchors>
                <Animations>
                    <AnimationGroup parentKey="FadeIn" setToFinalAlpha="true">
                        <Alpha childKey="mapBG" duration="0.2" fromAlpha="0" toAlpha="1"/>
                    </AnimationGroup>
                </Animations>
                <Layers>
                    <Layer level="BACKGROUND" textureSubLevel="1">
                        <Texture parentKey="mapBG" file="Interface/AddOns/GW2_UI/textures/questview/backgrounds/Misc/default" alpha="0">
                            <Size x="950" y="475"></Size>
                            <Anchors>
                                <Anchor point="TOP"/>
                            </Anchors>
                        </Texture>
                    </Layer>
                    <Layer level="BACKGROUND" textureSubLevel="2">
                        <Texture parentKey="blackout_head">
                            <Size x="950" y="96"/>
                            <Anchors>
                                <Anchor point="TOP"/>
                            </Anchors>
                            <Color r="0" g="0" b="0"/>
                        </Texture>
                        <Texture parentkey="blackout_fade">
                            <Size x="950" y="8"/>
                            <Anchors>
                                <Anchor point="BOTTOM" relativeKey="$parent.blackout_head" y="-8"/>
                            </Anchors>
                            <Color r="0" g="0" b="0"/>
                            <Gradient orientation="VERTICAL">
                                <MinColor r="0" g="0" b="0" a="0"/>
                                <MaxColor r="0" g="0" b="0" a="1"/>
                            </Gradient>
                        </Texture>
                    </Layer>
                </Layers>
                <Frames>
                    <DressUpModel parentKey="playerModel" alpha="0" mixin="GwImmersiveQuestingPlayerModelMixin">
                        <Size x="474" y="474"></Size>
                        <Anchors>
                            <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT" x="0" y="1"/>
                        </Anchors>
                        <Scripts>
                            <OnShow method="OnShow"/>
                            <OnHide method="OnHide"/>
                            <OnModelLoaded method="OnModelLoaded"/>
                        </Scripts>
                        <Animations>
                            <AnimationGroup parentKey="FadeIn" setToFinalAlpha="true">
                                <Alpha duration="0.3" fromAlpha="0" toAlpha="1"/>
                            </AnimationGroup>
                        </Animations>
                    </DressUpModel>
                    <CinematicModel parentKey="giverModel" alpha="0" mixin="GwImmersiveQuestingGiverModelMixin">
                        <Size x="700" y="474"></Size>
                        <Anchors>
                            <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT" x="0" y="1"/>
                        </Anchors>
                        <Scripts>
                            <OnHide method="OnHide"/>
                            <OnModelLoaded method="OnModelLoaded"/>
                            <OnAnimFinished method="OnAnimFinished"/>
                        </Scripts>
                        <Animations>
                            <AnimationGroup parentKey="FadeIn" setToFinalAlpha="true">
                                <Alpha duration="0.3" fromAlpha="0" toAlpha="1"/>
                            </AnimationGroup>
                        </Animations>
                    </CinematicModel>
                    <Frame parentKey="dialog" enableMouse="true">
                        <Size x="950" y="374"></Size>
                        <Anchors>
                            <Anchor point="center" x="0" y="-50"/>
                        </Anchors>
                        <Layers>
                            <Layer level="OVERLAY" textureSubLevel="1">
                                <Texture parentKey="blackout_feet">
                                    <Size x="952" y="101"/>
                                    <Anchors>
                                        <Anchor point="BOTTOM" y="-1"/>
                                    </Anchors>
                                    <Color r="0" g="0" b="0"/>
                                </Texture>
                            </Layer>
                            <Layer level="OVERLAY" textureSubLevel="2">
                                <FontString parentKey="text" inherits="GwImmersiveQuestingDialogFont" justifyV="MIDDLE" spacing="5.0" maxLines="3">
                                    <Size x="750" y="90"></Size>
                                    <Anchors>
                                        <Anchor point="BOTTOM" relativePoint="BOTTOM" x="0" y="10"/>
                                    </Anchors>
                                </FontString>
                            </Layer>
                        </Layers>
                    </Frame>
                    <Frame inherits="GwImmersiveQuestingSummaryFrameTemplate" parentKey="summary" hidden="true">
                        <Anchors>
                            <Anchor point="center" x="0" y="-50"/>
                        </Anchors>
                    </Frame>
                    <Frame parentKey="floaty">
                        <Size x="952" y="474"></Size>
                        <Anchors>
                            <Anchor point="TOP" relativePoint="TOP" x="0" y="0"/>
                        </Anchors>
                        <Layers>
                            <Layer level="OVERLAY" textureSubLevel="3">
                                <FontString parentKey="title" inherits="GwImmersiveQuestingTitleFont" justifyV="MIDDLE" justifyH="CENTER">
                                    <Size y="90"/>
                                    <Anchors>
                                        <Anchor point="TOP" relativePoint="TOP" x="0" y="0"/>
                                    </Anchors>
                                </FontString>
                                <Texture parentKey="inset" file="Interface/AddOns/GW2_UI/textures/questview/overlay_bottom.png">
                                    <Size x="952" y="475"></Size>
                                    <Anchors>
                                        <Anchor point="bottom" x="0" y="-1"/>
                                    </Anchors>
                                </Texture>
                            </Layer>
                        </Layers>
                    </Frame>

                    <Button parentKey="acceptButton" inherits="GwImmersiveQuestingButtonTemplate" frameLevel="10" hidden="true">
                        <Anchors>
                            <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" x="5" y="10"/>
                        </Anchors>
                    </Button>
                    <Button parentKey="cancelButton" inherits="GwImmersiveQuestingButtonTemplate" frameLevel="10" hidden="true">
                        <Anchors>
                            <Anchor point="TOPRIGHT" relativePoint="BOTTOMRIGHT" x="-5" y="10"/>
                        </Anchors>
                    </Button>

                </Frames>
            </Frame>

        </Frames>
    </Frame>
</Ui>
