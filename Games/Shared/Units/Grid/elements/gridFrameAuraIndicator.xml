<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">

    <Frame name="GwGridFrameAuraIndicator" hidden="true" virtual="true" frameLevel="20">
        <Size x="13" y="13"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture file="Interface/AddOns/GW2_UI/textures/uistuff/gwstatusbar.png">
                    <Color r="0" g="0" b="0" a="1"></Color>
                    <Anchors>
                        <Anchor point="TOPLEFT" x="0" y="0.3"></Anchor>
                        <Anchor point="BOTTOMRIGHT"></Anchor>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <Texture parentKey="icon">
                    <Anchors>
                        <Anchor point="TOPLEFT" x=".7" y="-0.7"></Anchor>
                        <Anchor point="BOTTOMRIGHT" x="-0.7" y="0.7"></Anchor>
                    </Anchors>
                    <TexCoords left="0.1" right="0.9" top="0.1" bottom="0.9" />
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Cooldown parentKey="cooldown" setAllPoints="true" reverse="true" hideCountdownNumbers="true" hidden="true" inherits="CooldownFrameTemplate" frameLevel="21">
                <SwipeTexture>
                    <Color r="0" g="0" b="0" a="0.7"/>
                </SwipeTexture>
            </Cooldown>
            <Frame parentKey="textFrame" setAllPoints="true" frameLevel="22">
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="text" inherits="GameFontNormalSmall" justifyH="CENTER" justifyV="MIDDLE" outline="NORMAL" hidden="true">
                            <Color r="1" g="1" b="1"/>
                            <Anchors>
                                <Anchor point="TOPLEFT" x="0" y="1"/>
                                <Anchor point="BOTTOMRIGHT" x="0" y="1"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
            </Frame>
        </Frames>
    </Frame>
</Ui>
